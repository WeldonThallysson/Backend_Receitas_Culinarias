{
  "compilerOptions": {
    "target": "ES2020",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "isolatedModules": true,

    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["jest", "node"]
  },

  "include": ["src", "__tests__"],
  "exclude": ["node_modules", "dist"]
}